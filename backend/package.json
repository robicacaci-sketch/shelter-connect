{
  "name": "housing-readiness-backend",
  "version": "1.0.0",
  "description": "Backend API for Housing Readiness Tracker (Node.js/Express + SQLite)",
  "keywords": [
    "nodejs",
    "express",
    "sqlite"
  ],
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.7.4",
    "multer": "^2.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
